{
  "name": "@tinyhref/tinystore",
  "version": "0.0.1",
  "description": "",
  "keywords": [
    "state-management",
    "hooks",
    "react-hook",
    "react-context"
  ],
  "license": "MIT",
  "author": {
    "name": "TinyHref",
    "website": "https://tinyhref.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tinyhref/tinystore"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./react": {
      "types": "./src/react/index.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.js",
      "default": "./src/react/index.ts"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./*"
      ]
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src --dts",
    "dev": "pnpm build:fast --watch",
    "clean": "rimraf dist .turbo",
    "typecheck": "tsc --noEmit",
    "build:fast": "tsup src",
    "prepack": "clean-package",
    "postpack": "clean-package restore"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "clean-package": "2.2.0",
    "react": "^18.3.0",
    "tsup": "8.5.0",
    "typescript": "5.4.5"
  },
  "clean-package": "./clean-package.config.json"
}